{
  "manifest_version": 3,
  "name": "Career Connect",
  "version": "1.1.1",
  "description": "Automates LinkedIn connection requests with sequential processing and random delays",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "dist/background.dev.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Career Connect"
  },
  "web_accessible_resources": [{"resources": ["report.html"], "matches": ["<all_urls>"]}]
}
