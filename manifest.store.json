{
  "manifest_version": 3,
  "name": "LinkedIn Connection Assistant",
  "version": "1.0",
  "description": "Prepare LinkedIn connection invite drafts one at a time, then review and send them yourself.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/search/results/people/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/results/people/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_popup": "popup.store.html",
    "default_title": "Connection Assistant"
  }
}
