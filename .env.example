# Chrome Web Store publish credentials — required by `npm run webstore:upload`
# and `npm run webstore:publish`. Copy to `.env`, fill in real values, and load
# them into your shell before running those scripts (this repo does not
# auto-load .env files). Never commit the real .env.
#
# One-time setup to obtain these values: https://github.com/fregante/chrome-webstore-upload-keys
CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=
PUBLISHER_ID=
